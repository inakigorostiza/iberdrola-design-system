{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Iberdrola Design System — source-of-truth design tokens (W3C Design Tokens format). Reverse-engineered from brand logos + iberdrola.es. Consumed by tokens/*.css. Change a value here, mirror it in the matching CSS file.",
  "color": {
    "$type": "color",
    "green": {
      "50":  { "$value": "#EAF7EF" },
      "100": { "$value": "#CDEBD9", "$description": "mint tint used for soft section backgrounds" },
      "150": { "$value": "#E8F3EC" },
      "200": { "$value": "#A6DFBB" },
      "300": { "$value": "#6FCB91" },
      "400": { "$value": "#33B568" },
      "500": { "$value": "#00A443", "$description": "PRIMARY brand green" },
      "600": { "$value": "#00913B" },
      "700": { "$value": "#00823A", "$description": "button hover / active" },
      "800": { "$value": "#006B33" },
      "900": { "$value": "#004A2F", "$description": "deep forest green — dark hero/footer bands" },
      "950": { "$value": "#013D28" }
    },
    "orange": {
      "300": { "$value": "#FFC170" },
      "500": { "$value": "#FF9C1A", "$description": "accent orange — secondary CTA / icon accents" },
      "600": { "$value": "#E8850A" }
    },
    "blue": {
      "300": { "$value": "#7DCEFF" },
      "500": { "$value": "#0DA9FF", "$description": "accent blue — logo / links on dark / info" },
      "600": { "$value": "#008FE0" }
    },
    "neutral": {
      "0":   { "$value": "#FFFFFF" },
      "50":  { "$value": "#F6F7F5", "$description": "off-white page background" },
      "100": { "$value": "#EEEFEC" },
      "200": { "$value": "#E1E3DE" },
      "300": { "$value": "#C9CCC5" },
      "400": { "$value": "#9DA29A" },
      "500": { "$value": "#6B7280", "$description": "muted / secondary text" },
      "600": { "$value": "#4B5148" },
      "700": { "$value": "#333333", "$description": "body text" },
      "800": { "$value": "#242424" },
      "900": { "$value": "#1A1A1A", "$description": "headings / ink" }
    },
    "tint": {
      "mint": { "$value": "#E8F3EC" },
      "peach": { "$value": "#FCEFE3" },
      "sky": { "$value": "#E7F4FC" },
      "sand": { "$value": "#FBF6EC" }
    },
    "semantic": {
      "success": { "$value": "#00A443" },
      "warning": { "$value": "#FF9C1A" },
      "error":   { "$value": "#D92D20" },
      "info":    { "$value": "#0DA9FF" }
    }
  },
  "gradient": {
    "$type": "gradient",
    "brand-tricolor": { "$value": "linear-gradient(120deg, #00A443 0%, #0DA9FF 55%, #FF9C1A 100%)" },
    "forest": { "$value": "linear-gradient(160deg, #006B33 0%, #013D28 100%)" }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "brand": { "$value": ["Iberdrola", "Figtree", "Segoe UI", "system-ui", "-apple-system", "sans-serif"] },
      "mono":  { "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"] }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "display": { "$value": "clamp(2.75rem, 1.6rem + 4.6vw, 4.5rem)" },
      "h1": { "$value": "clamp(2.25rem, 1.5rem + 3vw, 3.25rem)" },
      "h2": { "$value": "clamp(1.75rem, 1.25rem + 2vw, 2.5rem)" },
      "h3": { "$value": "clamp(1.375rem, 1.1rem + 1.1vw, 1.75rem)" },
      "h4": { "$value": "1.25rem" },
      "h5": { "$value": "1.125rem" },
      "h6": { "$value": "1rem" },
      "body-lg": { "$value": "1.125rem" },
      "body":    { "$value": "1rem" },
      "body-sm": { "$value": "0.875rem" },
      "caption": { "$value": "0.75rem" },
      "overline": { "$value": "0.75rem" }
    },
    "lineHeight": {
      "tight": { "$value": "1.1" },
      "snug":  { "$value": "1.25" },
      "normal": { "$value": "1.5" },
      "relaxed": { "$value": "1.7" }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "4px base scale",
    "0": { "$value": "0" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "3rem" },
    "8": { "$value": "4rem" },
    "9": { "$value": "6rem" },
    "10": { "$value": "8rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "8px" },
    "md": { "$value": "12px" },
    "lg": { "$value": "16px" },
    "xl": { "$value": "24px" },
    "2xl": { "$value": "32px" },
    "pill": { "$value": "999px" }
  },
  "shadow": {
    "$type": "shadow",
    "xs": { "$value": "0 1px 2px rgba(1, 61, 40, 0.06)" },
    "sm": { "$value": "0 2px 8px rgba(1, 61, 40, 0.08)" },
    "md": { "$value": "0 8px 24px rgba(1, 61, 40, 0.10)" },
    "lg": { "$value": "0 16px 48px rgba(1, 61, 40, 0.14)" }
  },
  "size": {
    "$type": "dimension",
    "container": { "$value": "1280px" },
    "container-narrow": { "$value": "960px" },
    "container-wide": { "$value": "1440px" }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "150ms" },
      "base": { "$value": "250ms" },
      "slow": { "$value": "400ms" },
      "slower": { "$value": "700ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0, 0, 1] },
      "decelerate": { "$value": [0, 0, 0.2, 1] },
      "accelerate": { "$value": [0.4, 0, 1, 1] },
      "spring": { "$value": [0.34, 1.56, 0.64, 1] }
    }
  },
  "zIndex": {
    "base": { "$value": 1 },
    "dropdown": { "$value": 1000 },
    "sticky": { "$value": 1100 },
    "overlay": { "$value": 1200 },
    "modal": { "$value": 1300 },
    "toast": { "$value": 1400 }
  }
}
